{
  "task": "optimization",
  "data": {
    "input_column": "SMILES",
    "response_column": "KSOL",
    "training_dataset_file": "~/dockerimages/QSARTuna/Openadment_expansion_all_training_main.csv"
  },
  "descriptors": [
    {
      "name": "SmilesAndSideInfoFromFile",
      "parameters": {
        "file": "~/dockerimages/QSARTuna/Openadment_expansion_all_training_side_info.csv",
        "input_column": "SMILES",
        "y_aux_column": "ylabels" ,
        "y_aux_weight_pc": {
                "low": 0,
                "high": 100,
                "q": 10}
      }
    }
  ],
  "settings": {
    "mode": "regression",
    "n_splits":2,
    "n_replicates": 2,
    "direction": "maximize",
    "n_startup_trials": 1,
    "n_trials": 15,
    "n_jobs": 4
  },
  "algorithms": [
    {
      "name": "ChemPropRegressor",
      "parameters": {
        "aggregation_norm": {
          "low": 100,
          "high": 100
        },
        "batch_size": [64],
        "ensemble_size": 1,
        "epochs": 10,
        "depth": {
          "low": 2,
          "high": 6
        },
        "ffn_hidden_dim": {
          "low": 300,
          "high": 2400
        },
        "ffn_num_layers": {
          "low": 1,
          "high": 4
        },
        "final_lr_ratio": {
          "low": 1e-2,
          "high": 1e-2
        },
        "message_hidden_dim": {
          "low": 300,
          "high": 2400
        },
        "init_lr_ratio": {
          "low": 1e-2,
          "high": 1e-2
        },
        "max_lr": {
          "low": 1e-2,
          "high": 1e-2
        },
        "warmup_epochs_ratio": {
          "low": 0.1,
          "high": 0.1
        },
        "activation": ["RELU"],
        "aggregation": ["norm"],
        "loss_function": ["mve"],
        "undirected": [true],
        "message_bias": [true],
        "batch_norm": [true,false],
        "molecule_featurizers": ["morgan_binary", "morgan_count"]
              }
    }
  ]
}
